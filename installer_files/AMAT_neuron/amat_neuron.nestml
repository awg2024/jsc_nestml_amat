# it under the terms of the GNU General Public License as published by
# the Free Software Foundation, either version 2 of the License, or
# (at your option) any later version.
#
# NEST is distributed in the hope that it will be useful,
# but WITHOUT ANY WARRANTY; without even the implied warranty of
# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
# GNU General Public License for more details.
#
# You should have received a copy of the GNU General Public License
# along with NEST.  If not, see <http://www.gnu.org/licenses/>.

model amat_neuron:
    state:
        # spike-history threshold (oringal MAT neuronal model)
        V_th_alpha_1 mV = 0 mV      # theta_1(t): short-timescale spike-history threshold
        V_th_alpha_2 mV = 0 mV      # theta_2(t): long-timescale spike-history threshold

        # voltage-dependent threshold (AMAT extension)
        V_th_v mV = 0 mV           # theta_V(t): voltage-dependent threshold term
        V_th_v_aux mV/ms = 0 mV/ms # Auxiliary variable w = dtheta_V/dt + theta_V/tau_V,
                                   # needed to express the alpha-kernel convolution as two
                                   # coupled first-order ODEs instead of one 2nd-order ODE. 

        # membrane potential and refractory timer 
        V_m mV = E_L        # Absolute membrane potential; never reset on spike
        refr_t ms = 0 ms    # Refractory period timer; counts down to 0 after a spike

    equations:

        # Exponential-shaped postsynaptic current kernels (unchanged from mat2_psc_exp)
        kernel I_kernel_inh = exp(-t / tau_syn_inh) # inhibitory kernel # inhibitory PSC waveform
        kernel I_kernel_exc = exp(-t / tau_syn_exc) # excitatory kernel # excitatory PSC waveform

        # decay ODEs for slow and fast adaptation (from mat2_psc_exp)
        V_th_alpha_1' = -V_th_alpha_1 / tau_1
        V_th_alpha_2' = -V_th_alpha_2 / tau_2
        
        # Total synaptic current: excitatory minus inhibitory, each convolved with its kernel
        inline I_syn pA = unit_psc * (convolve(I_kernel_exc, exc_spikes) - convolve(I_kernel_inh, inh_spikes))

        # dV/dt, written once and reused below so the voltage-dependent threshold
        # is driven by exactly the same rate-of-change that updates V_m itself.
        inline dV_dt mV/ms = -(V_m - E_L) / tau_m + (I_syn + I_e + I_stim) / C_m

        # Membrane potential ODE: tau_m * dV/dt = -(V-E_L) + R*I  (unchanged from mat2_psc_exp)
        V_m' = dV_dt

        # The AMAT voltage-dependent threshold pair
        # Single second-order ODE into the two coupled first-order ODEs below: 
        V_th_v_aux' = -V_th_v_aux / tau_V + beta * dV_dt
        V_th_v' = -V_th_v / tau_V + V_th_v_aux

        refr_t' = -1e3 * ms/s    # refractoriness is implemented as an ODE, representing a timer counting back down to zero. 

    parameters:
        
        # membrane parameters (unchanged from mat2_psc_exp) 
        tau_m ms = 10 ms          # Membrane time constant (Yamauchi et al. explicitly states to use 10 ms)
        C_m pF = 100 pF          # Capacitance of the membrane
        refr_T ms = 2 ms         # Duration of refractory period
        E_L mV = -70 mV          # Resting potential
        tau_syn_exc ms = 1 ms    # Time constant of postsynaptic excitatory currents
        tau_syn_inh ms = 3 ms    # Time constant of postsynaptic inhibitory currents
        
        # spike-history threshold parameters (unchanged from mat2_psc_exp) 
        tau_1 ms = 10 ms         # Short time constant of adaptive threshold
        tau_2 ms = 200 ms        # Long time constant of adaptive threshold
        alpha_1 mV = 37 mV       # Amplitude of short time threshold adaptation [3]
        alpha_2 mV = 2 mV        # Amplitude of long time threshold adaptation [3]
        omega mV = 19 mV         # Resting spike threshold (absolute value, not relative to E_L)

        # voltage-dependent threshold parameters (new, AMAT extension) 
        tau_V ms = 5 ms          # Timescale of the voltage-dependency kernel K(s)=s*exp(-s/tau_V) [4]
        beta 1/ms = 0 / ms       # Strength/sign of voltage dependency. beta=0 recovers mat2_psc_exp
                                 # exactly. Negative beta -> phasic/rebound-type behaviour;
                                 # positive beta -> resonator/subthreshold-oscillation-type behaviour [4]

        # constant external input current
        I_e pA = 0 pA

    internals:
        unit_psc pA = 1 pA        # Unitary postsynaptic current amplitude

    input:
        exc_spikes <- excitatory spike  # Incoming excitatory spikes
        inh_spikes <- inhibitory spike  # Incoming inhibitory spikes
        I_stim pA <- continuous         # Externally injected continuous current

    output:
        spike                            # This neuron emits spike events

    
    update:
        if refr_t > 0 ms:
            
            # Neuron is absolute refractory: only the refractory timer counts down.
            # V_m is frozen (not integrated) here, and so are V_th_v/V_th_v_aux --
            # since they are driven by dV/dt, freezing them together with V_m avoids
            # generating a spurious voltage-derivative signal from a variable that
            # isn't actually being updated this step.
            integrate_odes(refr_t)
        else:
            
            # re-do commentry here, we took out the intenral exponentials? 
            integrate_odes(V_m, V_th_v_aux, V_th_v, V_th_alpha_1, V_th_alpha_2)
    
    onCondition(refr_t <= 0 ms and V_m >= E_L + omega + V_th_alpha_1 + V_th_alpha_2):
        # Spike condition: V_m has crossed theta(t) = E_L + omega + theta_1 + theta_2 + theta_V
        # (all three threshold components, summed, per Eq. 16 of Yamauchi et al. 2011)

        refr_t = refr_T    # start of the refractory period

        # Only the spike-history terms jump on a spike. V_th_v/V_th_v_aux are
        # deliberately NOT reset or bumped here: theta_V has no spike-triggered
        # jump in the AMAT model, it is purely a continuous filter of dV/dt.
        V_th_alpha_1 += alpha_1 # short adaptation time
        V_th_alpha_2 += alpha_2 # long adaptation time

        emit_spike()
